{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aipowergrid.io/schemas/model-manifest-v1.json",
  "title": "AI Power Grid Model Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "slug",
    "version",
    "display_name",
    "modalities",
    "worker_model_names",
    "min_vram_mib",
    "artifacts",
    "runtime",
    "license"
  ],
  "properties": {
    "schema": {
      "const": "aipg.model-manifest.v1"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "modalities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "text",
          "image",
          "video",
          "audio",
          "3d"
        ]
      }
    },
    "worker_model_names": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128
      }
    },
    "min_vram_mib": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "filename",
          "sha256",
          "size_bytes",
          "source_uri"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "filename": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 1
          },
          "source_uri": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          }
        }
      }
    },
    "runtime": {
      "type": "object"
    },
    "license": {
      "type": "object"
    }
  }
}
